{
  "name": "teamcity-cloud-agent-updater",
  "version": "1.0.0",
  "description": "Updates image references in TeamCity Cloud Agents",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --maxWorkers=2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OctopusDeploy/TeamCityCloudAgentUpdater.git"
  },
  "author": "Matt Richardson",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/OctopusDeploy/TeamCityCloudAgentUpdater/issues"
  },
  "homepage": "https://github.com/OctopusDeploy/TeamCityCloudAgentUpdater#readme",
  "dependencies": {
    "colors": "1.4.0",
    "commander": "15.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "jest-teamcity-reporter": "^0.9.0"
  }
}
